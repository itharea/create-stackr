name: Tests

on:
  push:
    branches: [main]
  pull_request:

jobs:
  component:
    runs-on: ubuntu-latest
    strategy:
      fail-fast: false
      matrix:
        service:
<% services.filter((s) => s.backend.tests).forEach((s) => { -%>
          - <%= s.name %>
<% }); -%>
    steps:
      - uses: actions/checkout@v4
      - uses: oven-sh/setup-bun@v2
      - run: cp .env.example .env
      - run: docker compose -f docker-compose.test.yml --profile component up -d --wait
      - run: bun install
        working-directory: ${{ matrix.service }}/backend
      - run: bun run test
        working-directory: ${{ matrix.service }}/backend
      - run: docker compose -f docker-compose.test.yml --profile component down
        if: always()

  e2e:
    runs-on: ubuntu-latest
    needs: component
    steps:
      - uses: actions/checkout@v4
      - uses: oven-sh/setup-bun@v2
      - run: cp .env.example .env
      - run: docker compose -f docker-compose.test.yml --profile e2e up -d --build --wait
      - run: bun install
        working-directory: tests/e2e
      - run: bun run test
        working-directory: tests/e2e
      - run: docker compose -f docker-compose.test.yml --profile e2e down
        if: always()
