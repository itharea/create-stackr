// =============================================================================
// <%= projectName %> — one-shot setup script
// =============================================================================
// Generated by create-stackr. Invoked via `<%= packageManager %> run setup`.
//
//   1. Installs monorepo-root devDependencies (including the `stackr` CLI and
//      `inquirer`, which this script imports).
//   2. Checks for stale docker volumes from a prior project of the same name
//      and offers an inquirer-driven RESET prompt. Volumes that survive here
//      cause Postgres auth failures later when `docker compose up` runs.
//   3. Copies the root .env from .env.example if missing (real random
//      credentials were written at create-stackr time; this is a safety net
//      for users who deleted .env).
//   4. Per service: copies backend/.env and web/.env.local from their
//      .env.example peers, then runs `<%= packageManager %> install` in
//      every backend / web / mobile subproject.
//
// Re-run safely — existing .env files are never overwritten. The volume
// prompt only appears when matching docker volumes actually exist.
// =============================================================================

import { spawnSync } from 'node:child_process';
import { existsSync, copyFileSync } from 'node:fs';
import path from 'node:path';
import { fileURLToPath } from 'node:url';

const __dirname = path.dirname(fileURLToPath(import.meta.url));
const ROOT_DIR = path.resolve(__dirname, '..');
process.chdir(ROOT_DIR);

const PM = '<%= packageManager %>';
const PROJECT_NAME = '<%= projectName %>';
const SERVICES = [<% services.forEach((svc) => { -%>'<%= svc.name %>', <% }) -%>];

console.log(`📦 Setting up ${PROJECT_NAME}...`);

// ---------------------------------------------------------------------------
// Root .env (cheap, pre-install)
// ---------------------------------------------------------------------------
if (existsSync('.env')) {
  console.log('  ℹ️  Root .env already exists — skipping');
} else if (existsSync('.env.example')) {
  copyFileSync('.env.example', '.env');
  console.log('  ✅ Created root .env from .env.example');
}

// ---------------------------------------------------------------------------
// Monorepo-root devDependencies
// ---------------------------------------------------------------------------
// Installs BEFORE the volume-reset prompt because this script imports
// `inquirer` and the dep doesn't exist until the install resolves it.
// Non-fatal on failure — we continue and warn the user.
let rootInstallOK = false;
if (existsSync('package.json')) {
  console.log('');
  console.log('📦 Installing monorepo-root devDependencies...');
  const r = spawnSync(PM, ['install'], { stdio: 'inherit' });
  if (r.status === 0) {
    rootInstallOK = true;
    console.log('  ✅ Root devDependencies installed — `npx stackr` is now available');
  } else {
    console.log('');
    console.log("  ⚠️  Root install failed — the `stackr` CLI won't be available via npx.");
    console.log('     You can still use it globally:');
    console.log('       npm i -g create-stackr');
    console.log('       stackr add service <name>');
    console.log('');
    console.log('     Or retry the root install manually once the registry is reachable:');
    console.log(`       ${PM} install`);
    console.log('');
  }
}

// ---------------------------------------------------------------------------
// Docker volume conflict check (post-install so inquirer is importable)
// ---------------------------------------------------------------------------
function dockerAvailable() {
  const info = spawnSync('docker', ['info'], { stdio: 'ignore' });
  return info.status === 0;
}

function listProjectVolumes() {
  const composeProject = path.basename(ROOT_DIR);
  const prefix = `${composeProject}_`;
  const ls = spawnSync('docker', ['volume', 'ls', '--format', '{{.Name}}'], {
    encoding: 'utf-8',
  });
  if (ls.status !== 0 || !ls.stdout) return [];
  return ls.stdout
    .split('\n')
    .map((l) => l.trim())
    .filter((name) => name.length > 0 && name.startsWith(prefix));
}

async function maybeResetVolumes() {
  if (!rootInstallOK) {
    // inquirer is unavailable — bail rather than half-prompting.
    return;
  }
  if (!dockerAvailable()) return;
  const vols = listProjectVolumes();
  if (vols.length === 0) return;

  console.log('');
  console.log(`⚠️  Existing docker volumes detected for ${PROJECT_NAME}:`);
  for (const v of vols) console.log(`    • ${v}`);
  console.log('');
  console.log('These may be left over from a previous project of the same name.');
  console.log('Postgres / Redis will refuse to start if the volumes were initialised');
  console.log('with credentials that no longer match your .env files. You can:');
  console.log('  • keep the volumes (skip this prompt) if you know they hold real');
  console.log('    data you want to preserve');
  console.log('  • reset the volumes now — this DESTROYS all data in them');
  console.log('');

  const { default: inquirer } = await import('inquirer');
  const { answer } = await inquirer.prompt([
    {
      type: 'input',
      name: 'answer',
      message: "Destroy the volumes above? Type 'RESET' to confirm:",
    },
  ]);

  if (answer !== 'RESET') {
    console.log("  ℹ️  Keeping existing volumes (answer was not 'RESET')");
    console.log('');
    return;
  }

  console.log('  🧹 Stopping containers and removing volumes...');
  spawnSync('docker', ['compose', 'down', '-v'], { stdio: 'ignore' });
  if (existsSync('docker-compose.prod.yml')) {
    spawnSync(
      'docker',
      ['compose', '-f', 'docker-compose.prod.yml', 'down', '-v'],
      { stdio: 'ignore' }
    );
  }
  for (const v of vols) {
    const inspect = spawnSync('docker', ['volume', 'inspect', v], { stdio: 'ignore' });
    if (inspect.status !== 0) continue;
    const rm = spawnSync('docker', ['volume', 'rm', v], { stdio: 'ignore' });
    if (rm.status === 0) console.log(`    ✅ Removed ${v}`);
    else console.log(`    ⚠️  Could not remove ${v} (in use?)`);
  }
  console.log('  ✅ Volume reset complete');
  console.log('');
}

await maybeResetVolumes();

// ---------------------------------------------------------------------------
// Per-service env + install
// ---------------------------------------------------------------------------
function copyIfMissing(src, dest, label) {
  if (!existsSync(src) || existsSync(dest)) return;
  copyFileSync(src, dest);
  console.log(`  ✅ Created ${label}`);
}

function runInstall(cwd, label) {
  console.log(`  📦 Installing ${label} dependencies...`);
  const r = spawnSync(PM, ['install'], { cwd, stdio: 'inherit' });
  if (r.status !== 0) {
    console.log(`  ⚠️  ${PM} install failed in ${label} — retry manually.`);
  }
}

for (const svc of SERVICES) {
  console.log('');
  console.log(`🔧 Configuring service: ${svc}`);

  const backend = path.join(svc, 'backend');
  if (existsSync(backend)) {
    copyIfMissing(
      path.join(backend, '.env.example'),
      path.join(backend, '.env'),
      `${svc}/backend/.env`
    );
    runInstall(backend, `${svc}/backend`);
  }

  const web = path.join(svc, 'web');
  if (existsSync(web)) {
    copyIfMissing(
      path.join(web, '.env.example'),
      path.join(web, '.env.local'),
      `${svc}/web/.env.local`
    );
    runInstall(web, `${svc}/web`);
  }

  const mobile = path.join(svc, 'mobile');
  if (existsSync(mobile)) {
    runInstall(mobile, `${svc}/mobile`);
  }
}

console.log('');
console.log('✅ Setup complete.');
console.log('');
console.log('Next steps:');
console.log('  1. Review root .env and per-service backend/.env files');
console.log('  2. Start the stack:  <%= packageManager %> run docker:dev');
<% services.forEach((svc) => { -%>
console.log('  3. Dev <%= svc.name %> backend:  cd <%= svc.name %>/backend && <%= packageManager %> run dev:rest-api');
<% }); -%>
console.log('  4. Add a new service:  npx stackr add service <name>');
<% if (services.some((s) => s.backend.tests)) { -%>
console.log('  5. Run tests:');
console.log('       <%= packageManager %> run test      # component + unit (docker-compose.test.yml, --profile component)');
console.log('       <%= packageManager %> run test:e2e  # cross-service E2E (docker-compose.test.yml, --profile e2e)');
<% } -%>
console.log('');
