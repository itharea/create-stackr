#!/usr/bin/env bash
# =============================================================================
# <%= projectName %> — one-shot setup script
# =============================================================================
# Generated by create-stackr. Loops over every service defined in
# stackr.config.json and:
#   1. Checks for stale docker volumes from a prior project of the same
#      name and offers a confirmed RESET. Runs FIRST so the user isn't
#      forced to sit through dependency installs before hitting a
#      Postgres auth failure on `docker compose up`.
#   2. Creates the monorepo root .env from .env.example if missing
#      (real random credentials were written at create-stackr time;
#      this copy is only a safety net for users who deleted .env)
#   3. Installs monorepo-root devDependencies so the `stackr` CLI binary
#      from `create-stackr` is available inside the project. Non-fatal
#      — a transient registry / offline environment does not abort the
#      rest of setup.
#   4. Creates each service's backend/.env from backend/.env.example
#      (same safety-net caveat as above)
#   5. Runs `<%= packageManager %> install` in every backend / web / mobile
#      subproject
#
# Re-run safely — existing .env files are never overwritten. The volume
# prompt only appears when matching docker volumes actually exist, so
# re-runs of `./scripts/setup.sh` after a successful `docker compose up`
# will still see the prompt (that's intentional — it's your reminder
# that those volumes hold real data) and you can hit Enter to skip.
# =============================================================================

set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$ROOT_DIR"

echo "📦 Setting up <%= projectName %>..."

# --- Docker volume conflict check --------------------------------------------
# v0.4 ran `has_existing_volumes` unconditionally against
# `docker volume ls --format '{{.Name}}' | grep "^<project>_"` and it
# worked — it caught stale volumes left behind from a prior project of
# the same name no matter what state the .env files were in. v0.5
# initially gated the check on a flag that was only ever set when
# setup.sh itself re-copied a .env.example, which silently skipped the
# check on every fresh create-stackr run: the CLI already writes real
# random credentials into .env at init time, so setup.sh never rotates
# anything on a first run.
#
# Restore the v0.4 approach — unconditionally list volumes under the
# compose project namespace (the directory basename, which is what
# docker compose uses as the default project name) and offer a typed
# 'RESET' confirmation. Prefix match (case statement) rather than
# enumerating `<svc>_postgres_data` / `<svc>_redis_data` candidates so
# any current or future volume declared by the compose file (including
# custom ones added by `stackr add service`) is caught.
if command -v docker >/dev/null 2>&1 && docker info >/dev/null 2>&1; then
  COMPOSE_PROJECT="$(basename "$ROOT_DIR")"
  EXISTING_VOLUMES=()
  while IFS= read -r vol; do
    [ -z "$vol" ] && continue
    case "$vol" in
      "${COMPOSE_PROJECT}_"*) EXISTING_VOLUMES+=("$vol") ;;
    esac
  done < <(docker volume ls --format '{{.Name}}' 2>/dev/null || true)

  if [ ${#EXISTING_VOLUMES[@]} -gt 0 ]; then
    echo ""
    echo "⚠️  Existing docker volumes detected for <%= projectName %>:"
    for vol in "${EXISTING_VOLUMES[@]}"; do
      echo "    • $vol"
    done
    echo ""
    echo "These may be left over from a previous project of the same name."
    echo "Postgres / Redis will refuse to start if the volumes were initialised"
    echo "with credentials that no longer match your .env files. You can:"
    echo "  • keep the volumes (skip this prompt) if you know they hold real"
    echo "    data you want to preserve"
    echo "  • reset the volumes now — this DESTROYS all data in them"
    echo ""
    read -r -p "Destroy the volumes above? Type 'RESET' to confirm: " REPLY
    if [ "$REPLY" = "RESET" ]; then
      echo "  🧹 Stopping containers and removing volumes..."
      docker compose down -v 2>/dev/null || true
      if [ -f docker-compose.prod.yml ]; then
        docker compose -f docker-compose.prod.yml down -v 2>/dev/null || true
      fi
      # Belt-and-suspenders: in case some volumes weren't touched by
      # `down -v` (e.g., leftover from a renamed service), remove them
      # individually. Failures are logged but non-fatal.
      for vol in "${EXISTING_VOLUMES[@]}"; do
        if docker volume inspect "$vol" >/dev/null 2>&1; then
          docker volume rm "$vol" >/dev/null 2>&1 \
            && echo "    ✅ Removed $vol" \
            || echo "    ⚠️  Could not remove $vol (in use?)"
        fi
      done
      echo "  ✅ Volume reset complete"
    else
      echo "  ℹ️  Keeping existing volumes (answer was not 'RESET')"
    fi
    echo ""
  fi
fi

# --- Root .env ----------------------------------------------------------------
if [ ! -f .env ]; then
  if [ -f .env.example ]; then
    cp .env.example .env
    echo "  ✅ Created root .env from .env.example"
  fi
else
  echo "  ℹ️  Root .env already exists — skipping"
fi

# --- Monorepo root devDependencies --------------------------------------------
# The root package.json pins `create-stackr` as a devDependency so the
# `stackr` CLI binary (for `stackr add service`, `stackr migrations ack`,
# etc.) lands in `node_modules/.bin/stackr` and is reachable via
# `npx stackr` or `<%= packageManager %> run stackr`. Non-fatal: if the
# install fails (e.g. the CLI version isn't published yet, or the user
# is offline), we print a clear warning with a global-install fallback
# and continue with the per-service installs below.
if [ -f package.json ]; then
  echo ""
  echo "📦 Installing monorepo-root devDependencies..."
  if <%= packageManager %> install; then
    echo "  ✅ Root devDependencies installed — `npx stackr` is now available"
  else
    echo ""
    echo "  ⚠️  Root install failed — the `stackr` CLI won't be available via npx."
    echo "     You can still use it globally:"
    echo "       npm i -g create-stackr"
    echo "       stackr add service <name>"
    echo ""
    echo "     Or retry the root install manually once the registry is reachable:"
    echo "       <%= packageManager %> install"
    echo ""
  fi
fi

# --- Per-service backend .env + install ---------------------------------------
SERVICES=(<% services.forEach((svc) => { %>"<%= svc.name %>" <% }); %>)

for svc in "${SERVICES[@]}"; do
  echo ""
  echo "🔧 Configuring service: $svc"

  if [ -d "$svc/backend" ]; then
    if [ ! -f "$svc/backend/.env" ] && [ -f "$svc/backend/.env.example" ]; then
      cp "$svc/backend/.env.example" "$svc/backend/.env"
      echo "  ✅ Created $svc/backend/.env"
    fi

    echo "  📦 Installing $svc/backend dependencies..."
    (cd "$svc/backend" && <%= packageManager %> install)
  fi

  if [ -d "$svc/web" ]; then
    if [ ! -f "$svc/web/.env.local" ] && [ -f "$svc/web/.env.example" ]; then
      cp "$svc/web/.env.example" "$svc/web/.env.local"
      echo "  ✅ Created $svc/web/.env.local"
    fi

    echo "  📦 Installing $svc/web dependencies..."
    (cd "$svc/web" && <%= packageManager %> install)
  fi

  if [ -d "$svc/mobile" ]; then
    echo "  📦 Installing $svc/mobile dependencies..."
    (cd "$svc/mobile" && <%= packageManager %> install)
  fi
done

echo ""
echo "✅ Setup complete."
echo ""
echo "Next steps:"
echo "  1. Review root .env and per-service backend/.env files"
echo "  2. Start the stack:  docker compose up -d"
<% services.forEach((svc) => { -%>
echo "  3. Dev <%= svc.name %> backend:  cd <%= svc.name %>/backend && <%= packageManager %> run dev:rest-api"
<% }); -%>
echo "  4. Add a new service:  npx stackr add service <name>"
echo ""
