# =============================================================================
# <%= projectName %> — root environment configuration
# =============================================================================
# Copy this file to .env at the monorepo root:
#
#     cp .env.example .env
#
# Docker Compose reads variables from this file to parameterize the
# per-service db, redis, and backend containers. Per-service code reads
# secrets from each service's own backend/.env (copied from the
# committed backend/.env.example during setup).
# =============================================================================

# Log level shared across services
LOG_LEVEL=info

# >>> stackr managed env >>>
<% services.forEach((svc) => { const up = svc.name.toUpperCase().replace(/-/g, '_'); -%>
# ---- <%= svc.name %> ----
<%= up %>_DB_USER=postgres
<%= up %>_DB_PASSWORD=change-me-<%= svc.name %>-db
<%= up %>_DB_NAME=<%= projectName.toLowerCase().replace(/[^a-z0-9]/g, '_') %>_<%= svc.name.replace(/-/g, '_') %>
<%= up %>_REDIS_PASSWORD=change-me-<%= svc.name %>-redis

<% }); -%>
# <<< stackr managed env <<<
