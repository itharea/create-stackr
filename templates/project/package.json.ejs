<%
  const scripts = {
    stackr: 'stackr',
    setup: 'node scripts/setup.mjs',
    'docker:dev': 'docker compose up -d',
    'docker:prod': 'docker compose -f docker-compose.yml -f docker-compose.prod.yml up -d',
  };
  if (services.some((s) => s.backend.tests)) {
    scripts['test'] = 'node scripts/test-all.mjs';
    scripts['test:e2e'] = 'node scripts/test-e2e.mjs';
  }
-%>
{
  "name": "<%= projectName %>",
  "version": "0.1.0",
  "private": true,
  "description": "Monorepo scaffolded with create-stackr",
  "scripts": <%- JSON.stringify(scripts, null, 2).replace(/\n/g, '\n  ') %>,
  "devDependencies": {
    "create-stackr": "^<%= stackrVersion %>",
    "inquirer": "^10.0.0"
  }
}
