<% } else { -%>
// authMiddleware === 'none': no plugin body. Export a no-op so the server
// bootstrap can still import it unconditionally.
import fp from "fastify-plugin";
import { FastifyPluginAsync } from "fastify";

const authPlugin: FastifyPluginAsync = async (_server) => {
  // no-op: this service does not require authentication.
};

export default fp(authPlugin);
<% } -%>
