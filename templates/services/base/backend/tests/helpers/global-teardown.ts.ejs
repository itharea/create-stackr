import isCI from 'is-ci';
import { execa } from 'execa';
import nock from 'nock';
import path from 'path';

export default async function globalTeardown() {
  nock.cleanAll();
  nock.enableNetConnect();

  if (isCI) {
    const composePath = path.resolve(__dirname, '../../../../docker-compose.test.yml');
    // Only the `component` profile is torn down — the `e2e` profile (if
    // it's concurrently up, which it shouldn't be) owns its own lifecycle.
    await execa('docker', ['compose', '-f', composePath, '--profile', 'component', 'down'], {
      stdio: 'inherit',
    });
  }
  // Local runs: containers stay alive for fast re-runs (Goldberg §2.3).
}
