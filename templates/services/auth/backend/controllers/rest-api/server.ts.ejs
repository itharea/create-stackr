import fastify, { type FastifyInstance, type FastifyServerOptions } from "fastify";

import config from "./plugins/config";
import auth from "./plugins/auth";
import errorHandler from "./plugins/error-handler";
import authRoutes from "./routes/auth";
import deviceSessionRoutes from "./routes/device-sessions";
import healthRoutes from "./routes/health";
<% if (service.authConfig?.adminDashboard) { %>
import adminRoutes from "./routes/admin";
<% } %>
<% if (platforms.includes('web')) { %>
import oauthWebRoutes from "./routes/oauth-web";
import { initRedis } from "../../utils/redis";
<% } %>

const baseOptions: FastifyServerOptions = {
  ajv: {
    customOptions: {
      removeAdditional: "all",
      coerceTypes: true,
      useDefaults: true,
      formats: {
        'date-time': true,
      },
    },
  },
  logger: {
    level: process.env.LOG_LEVEL || 'info',
    transport: process.env.NODE_ENV === 'development' ? {
      target: 'pino-pretty',
      options: {
        translateTime: 'HH:MM:ss Z',
        ignore: 'pid,hostname',
      },
    } : undefined,
  },
  genReqId: () => `req_${Date.now()}_${Math.random().toString(36).substr(2, 9)}`,
};

/**
 * Build and fully-register the auth Fastify instance. Each call returns
 * a fresh instance so component tests can spin up isolated in-process
 * servers via `app.inject()`.
 */
export async function buildServer(overrides: FastifyServerOptions = {}): Promise<FastifyInstance> {
  const server = fastify({ ...baseOptions, ...overrides });

  await server.register(config);
  await server.register(errorHandler);
  await server.register(import('@fastify/cors'), {
    origin: process.env.NODE_ENV === 'production'
      ? (process.env.ALLOWED_ORIGINS?.split(',').map(o => o.trim()) || [])
      : true,
    credentials: true,
    allowedHeaders: ['Content-Type', 'Cookie', 'X-Device-Session-Token'],
    exposedHeaders: ['set-cookie'],
  });

  await server.register(auth);
<% if (platforms.includes('web')) { %>
  await initRedis();
<% } %>

  await server.register(healthRoutes, { prefix: "/health" });
  await server.register(authRoutes, { prefix: "/api/auth" });
  await server.register(deviceSessionRoutes, { prefix: "/device-sessions" });
<% if (platforms.includes('web')) { %>
  await server.register(oauthWebRoutes, { prefix: "/api/auth/web/oauth" });
<% } %>
<% if (service.authConfig?.adminDashboard) { %>
  await server.register(adminRoutes, { prefix: "/api/admin" });
<% } %>

  server.get("/", async (_request, reply) => {
    return reply.code(200).send({
      message: "<%= service.name %> API is running",
      service: "<%= service.name %>",
      timestamp: new Date().toISOString(),
      version: "1.0.0"
    });
  });

  await server.ready();
  return server;
}
