# Generated by stackr — used by `bun run test`.
# Credentials mirror the root `.env`; the test infra binds to its own
# ports (dev + 10000) so `bun run test` can run alongside the dev stack.
NODE_ENV=test
LOG_LEVEL=silent

DATABASE_URL="postgresql://<%= service.testInfra.dbUser %>:<%= service.testInfra.dbPassword %>@127.0.0.1:<%= service.testInfra.dbPort %>/<%= service.testInfra.dbName %>?schema=public"

REDIS_HOST=127.0.0.1
REDIS_PORT=<%= service.testInfra.redisPort %>
REDIS_PASSWORD=<%= service.testInfra.redisPassword %>

# BetterAuth needs a signing secret even in tests.
BETTER_AUTH_SECRET=test-auth-secret-not-for-prod
BETTER_AUTH_URL=http://127.0.0.1:<%= service.backend.port %>
