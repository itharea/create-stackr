<% const authConf = service.authConfig; -%>
import { describe, it, expect, beforeAll, afterAll } from 'vitest';
import type { FastifyInstance } from 'fastify';
import { createTestApp, closeTestApp } from '../../helpers/app.js';
import { uniqueEmail } from '../../helpers/unique.js';
<% if (authConf.emailVerification) { -%>
import { markEmailVerified } from '../../helpers/verify-user.js';
<% } -%>

describe('POST /api/auth/sign-in/email', () => {
  let app: FastifyInstance;
  beforeAll(async () => {
    app = await createTestApp();
  });
  afterAll(async () => {
    await closeTestApp(app);
  });

  it('returns a session cookie for a user that already signed up', async () => {
    const email = uniqueEmail('signin');
    const password = 'correcthorsebatterystaple';

    const signUp = await app.inject({
      method: 'POST',
      url: '/api/auth/sign-up/email',
      payload: { email, password, name: 'Test User' },
      headers: { 'content-type': 'application/json' },
    });
    expect(signUp.statusCode, signUp.body).toBe(200);

<% if (authConf.emailVerification) { -%>
    // Skip the OTP round-trip: flip emailVerified directly so sign-in can
    // succeed without a real email/SMTP. The OTP send was a no-op in tests
    // (see utils/email.ts), so there is nothing to "consume" here.
    await markEmailVerified(email);

<% } -%>
    const signIn = await app.inject({
      method: 'POST',
      url: '/api/auth/sign-in/email',
      payload: { email, password },
      headers: { 'content-type': 'application/json' },
    });
    expect(signIn.statusCode, signIn.body).toBe(200);
    const setCookie = signIn.headers['set-cookie'];
    expect(setCookie).toBeDefined();
  });
});
