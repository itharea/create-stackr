# Simplified Multi-stage Dockerfile for Node.js/Fastify Backend
# Clean architecture with explicit service stages
# Supports npm, yarn, and bun package managers

# =============================================================================
# Base Stage - Common setup for all services
# =============================================================================
<% if (packageManager === 'bun') { %>FROM oven/bun:alpine AS base<% } else { %>FROM node:alpine AS base<% } %>

# Install essential packages
RUN apk --no-cache add dumb-init ca-certificates

# Set working directory
WORKDIR /app

# Copy package files and lock file for dependency installation
COPY package*.json ./
<% if (packageManager === 'bun') { %>COPY bun.lock* ./<% } else if (packageManager === 'npm') { %>COPY package-lock.json ./<% } else { %>COPY yarn.lock ./<% } %>
<% if (backend.orm === 'prisma') { %>
COPY prisma/schema.prisma ./prisma/
COPY prisma.config.ts ./
<% } else if (backend.orm === 'drizzle') { %>
COPY drizzle/schema.ts ./drizzle/
COPY drizzle.config.ts ./
<% } %>
COPY .env ./

# Install dependencies and generate ORM client
<% if (packageManager === 'bun') { %>RUN bun install && bun run db:generate<% } else if (packageManager === 'npm') { %>RUN npm ci && npm run db:generate<% } else { %>RUN yarn install --frozen-lockfile && yarn db:generate<% } %>

# Copy source code
COPY . .

# =============================================================================
# Development Stages - For local development with hot reload
# =============================================================================
FROM base AS rest-api-dev
EXPOSE <%= service.backend.port %>
<% if (packageManager === 'bun') { %>CMD ["dumb-init", "bun", "run", "dev:rest-api"]<% } else if (packageManager === 'npm') { %>CMD ["dumb-init", "npm", "run", "dev:rest-api"]<% } else { %>CMD ["dumb-init", "yarn", "dev:rest-api"]<% } %>

FROM base AS event-queue-dev
<% if (packageManager === 'bun') { %>CMD ["dumb-init", "bun", "run", "dev:event-queue"]<% } else if (packageManager === 'npm') { %>CMD ["dumb-init", "npm", "run", "dev:event-queue"]<% } else { %>CMD ["dumb-init", "yarn", "dev:event-queue"]<% } %>

# =============================================================================
# Production Stages - Optimized for production deployment
# =============================================================================
<% if (packageManager === 'bun') { %>FROM oven/bun:alpine AS rest-api-prod<% } else { %>FROM node:alpine AS rest-api-prod<% } %>

# Install essential packages and create non-root user
RUN apk --no-cache add dumb-init ca-certificates \
<% if (packageManager === 'bun') { %>    && addgroup -g 1001 -S bunjs \
    && adduser -S backend -u 1001 -G bunjs<% } else { %>    && addgroup -g 1001 -S nodejs \
    && adduser -S backend -u 1001 -G nodejs<% } %>

WORKDIR /app

# All COPYs use `--chown=backend:<group>` so the `backend` user (created in
# the RUN above) owns every file on the way in. This avoids a closing
# `RUN chown -R /app` step, which on macOS with a large node_modules tree
# can take tens of seconds per image.

# Copy package files, lock file, and ORM schema first. Schema must be in
# place before `<%= packageManager %> install` so prisma's `postinstall →
# prisma generate` can find `prisma/schema.prisma`; drizzle users are
# unaffected but keep the same ordering for parity with the base stage.
<% const chownUser = packageManager === 'bun' ? 'backend:bunjs' : 'backend:nodejs'; -%>
COPY --chown=<%= chownUser %> package*.json ./
<% if (packageManager === 'bun') { %>COPY --chown=<%= chownUser %> bun.lock* ./<% } else if (packageManager === 'npm') { %>COPY --chown=<%= chownUser %> package-lock.json ./<% } else { %>COPY --chown=<%= chownUser %> yarn.lock ./<% } %>
<% if (backend.orm === 'prisma') { %>
COPY --chown=<%= chownUser %> prisma/schema.prisma ./prisma/
COPY --chown=<%= chownUser %> prisma.config.ts ./
<% } else if (backend.orm === 'drizzle') { %>
COPY --chown=<%= chownUser %> drizzle/schema.ts ./drizzle/
COPY --chown=<%= chownUser %> drizzle.config.ts ./
<% } %>
COPY --chown=<%= chownUser %> .env ./

# Full install (devDeps are needed for `tsc` in the build below) +
# (re)generate ORM client. `db:generate` is redundant for prisma (postinstall
# already ran) but required for drizzle; keeping both in one RUN avoids an
# extra layer. NODE_ENV is set to `production` only after the prune below
# so this install never auto-omits devDeps.
<% if (packageManager === 'bun') { %>RUN bun install && bun run db:generate<% } else if (packageManager === 'npm') { %>RUN npm ci && npm run db:generate<% } else { %>RUN yarn install --frozen-lockfile && yarn db:generate<% } %>

# Copy source code
COPY --chown=<%= chownUser %> . .

# Build the TypeScript application
<% if (packageManager === 'bun') { %>RUN bun run build<% } else if (packageManager === 'npm') { %>RUN npm run build<% } else { %>RUN yarn build<% } %>

# Prune devDeps now that build is complete, then lock in production env.
<% if (packageManager === 'bun') { %>RUN bun install --production<% } else if (packageManager === 'npm') { %>RUN npm prune --production<% } else { %>RUN yarn install --production --frozen-lockfile<% } %>
ENV NODE_ENV=production

# Switch to non-root user
USER backend

# Expose port and add health check
EXPOSE <%= service.backend.port %>
<% if (packageManager === 'bun') { %>HEALTHCHECK --interval=30s --timeout=5s --start-period=10s --retries=3 \
    CMD bun -e "const res = await fetch('http://localhost:<%= service.backend.port %>/'); process.exit(res.ok ? 0 : 1)"<% } else { %>HEALTHCHECK --interval=30s --timeout=5s --start-period=10s --retries=3 \
    CMD node -e "fetch('http://localhost:<%= service.backend.port %>/').then(r => process.exit(r.ok ? 0 : 1)).catch(() => process.exit(1))"<% } %>

# Start the REST API service
<% if (packageManager === 'bun') { %>CMD ["dumb-init", "bun", "run", "start:rest-api"]<% } else if (packageManager === 'npm') { %>CMD ["dumb-init", "npm", "run", "start:rest-api"]<% } else { %>CMD ["dumb-init", "yarn", "start:rest-api"]<% } %>

# =============================================================================
<% if (packageManager === 'bun') { %>FROM oven/bun:alpine AS event-queue-prod<% } else { %>FROM node:alpine AS event-queue-prod<% } %>

# Install essential packages and create non-root user
RUN apk --no-cache add dumb-init ca-certificates \
<% if (packageManager === 'bun') { %>    && addgroup -g 1001 -S bunjs \
    && adduser -S backend -u 1001 -G bunjs<% } else { %>    && addgroup -g 1001 -S nodejs \
    && adduser -S backend -u 1001 -G nodejs<% } %>

WORKDIR /app

# Copy package files, lock file, and ORM schema first. See rest-api-prod
# above for the postinstall ordering + `--chown` rationale.
<% const chownUserEQ = packageManager === 'bun' ? 'backend:bunjs' : 'backend:nodejs'; -%>
COPY --chown=<%= chownUserEQ %> package*.json ./
<% if (packageManager === 'bun') { %>COPY --chown=<%= chownUserEQ %> bun.lock* ./<% } else if (packageManager === 'npm') { %>COPY --chown=<%= chownUserEQ %> package-lock.json ./<% } else { %>COPY --chown=<%= chownUserEQ %> yarn.lock ./<% } %>
<% if (backend.orm === 'prisma') { %>
COPY --chown=<%= chownUserEQ %> prisma/schema.prisma ./prisma/
COPY --chown=<%= chownUserEQ %> prisma.config.ts ./
<% } else if (backend.orm === 'drizzle') { %>
COPY --chown=<%= chownUserEQ %> drizzle/schema.ts ./drizzle/
COPY --chown=<%= chownUserEQ %> drizzle.config.ts ./
<% } %>
COPY --chown=<%= chownUserEQ %> .env ./

# Full install (devDeps needed for `tsc`) + (re)generate ORM client
<% if (packageManager === 'bun') { %>RUN bun install && bun run db:generate<% } else if (packageManager === 'npm') { %>RUN npm ci && npm run db:generate<% } else { %>RUN yarn install --frozen-lockfile && yarn db:generate<% } %>

# Copy source code
COPY --chown=<%= chownUserEQ %> . .

# Build the TypeScript application
<% if (packageManager === 'bun') { %>RUN bun run build<% } else if (packageManager === 'npm') { %>RUN npm run build<% } else { %>RUN yarn build<% } %>

# Prune devDeps + lock in production env
<% if (packageManager === 'bun') { %>RUN bun install --production<% } else if (packageManager === 'npm') { %>RUN npm prune --production<% } else { %>RUN yarn install --production --frozen-lockfile<% } %>
ENV NODE_ENV=production

# Switch to non-root user
USER backend

# Start the event queue service
<% if (packageManager === 'bun') { %>CMD ["dumb-init", "bun", "run", "start:event-queue"]<% } else if (packageManager === 'npm') { %>CMD ["dumb-init", "npm", "run", "start:event-queue"]<% } else { %>CMD ["dumb-init", "yarn", "start:event-queue"]<% } %>
